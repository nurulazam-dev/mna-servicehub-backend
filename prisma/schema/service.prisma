model Service {
    id              String           @id @default(uuid())
    name            String           @unique
    description     String
    imageUrl        String?
    isActive        Boolean          @default(true)
    serviceRequests ServiceRequest[]
    reviews         Review[]
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt

    @@index([name])
    @@index([isActive])
    @@map("services")
}
