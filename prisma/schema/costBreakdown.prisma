model CostBreakdown {
    id             String         @id @default(uuid())
    requestId      String         @unique
    serviceRequest ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
    serviceCharge  Decimal        @default(0) @db.Decimal(10, 2)
    productCost    Decimal        @default(0) @db.Decimal(10, 2)
    additionalCost Decimal        @default(0) @db.Decimal(10, 2)
    totalAmount    Decimal        @default(0) @db.Decimal(10, 2)

    @@map("cost_breakdowns")
}
