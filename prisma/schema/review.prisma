model Review {
    id              String          @id @default(uuid())
    requestId       String          @unique
    serviceRequest  ServiceRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
    serviceId       String
    service         Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    providerId      String
    serviceProvider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
    customerId      String
    customer        User            @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
    rating          Int
    comment         String?         @db.Text
    createdAt       DateTime        @default(now())

    @@index([requestId])
    @@index([providerId])
    @@index([customerId])
    @@index([serviceId])
    @@map("reviews")
}
