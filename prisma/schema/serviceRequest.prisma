model ServiceRequest {
    id                 String               @id @default(uuid())
    customerId         String
    customer           User                 @relation("CustomerServiceRequests", fields: [customerId], references: [id], onDelete: Cascade)
    providerId         String?
    provider           ServiceProvider?     @relation("ServiceProviderJobs", fields: [providerId], references: [id], onDelete: Cascade)
    serviceId          String
    service            Service              @relation(fields: [serviceId], references: [id])
    scheduleId         String?              @unique
    schedule           ServiceSchedule?     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
    serviceDescription String               @db.Text
    serviceAddress     String
    activePhone        String
    status             ServiceRequestStatus @default(PENDING)
    isDeleted          Boolean              @default(false)
    rejectionReason    String?
    createdAt          DateTime             @default(now())
    updatedAt          DateTime             @updatedAt
    costBreakdown      CostBreakdown?
    payment            Payment?
    paymentStatus      PaymentStatus        @default(UNPAID)
    review             Review?

    @@index([customerId])
    @@index([providerId])
    @@index([status])
    @@map("service_requests")
}
