<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Service Request Accepted | MNA ServiceHub</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap");

      body {
        margin: 0;
        padding: 0;
        background-color: #f4f7fa;
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          sans-serif;
        color: #1a202c;
      }

      .wrapper {
        width: 100%;
        padding: 40px 0;
        background-color: #f4f7fa;
      }

      .container {
        max-width: 600px;
        background-color: #ffffff;
        margin: 0 auto;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid #e2e8f0;
      }

      .header {
        background: linear-gradient(135deg, #0052cc 0%, #003d99 100%);
        padding: 35px 20px;
        text-align: center;
      }

      .header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 24px;
        font-weight: 800;
        letter-spacing: -0.5px;
      }

      .content {
        padding: 40px 35px;
      }

      .content h2 {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 10px;
        color: #111827;
        text-align: center;
      }

      .status-badge {
        display: block;
        width: fit-content;
        margin: 0 auto 25px;
        background-color: #ecfdf5;
        color: #059669;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
      }

      .greeting {
        font-size: 15px;
        line-height: 1.6;
        color: #4b5563;
        margin-bottom: 25px;
      }

      .user-name {
        font-weight: 700;
        color: #0052cc;
      }

      /* Information Card Design */
      .info-section {
        background-color: #f8faff;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        border: 1px solid #e2e8f0;
      }

      .info-header {
        font-size: 13px;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 8px;
      }

      .info-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        font-size: 14px;
      }

      .label {
        color: #64748b;
        font-weight: 500;
      }

      .value {
        color: #1e293b;
        font-weight: 600;
        text-align: right;
      }

      .provider-card {
        background-color: #ffffff;
        border: 2px solid #0052cc;
        border-radius: 12px;
        padding: 20px;
        margin: 30px 0;
        position: relative;
      }

      .provider-tag {
        position: absolute;
        top: -12px;
        left: 20px;
        background-color: #0052cc;
        color: white;
        padding: 2px 12px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 700;
      }

      .footer {
        background-color: #f9fafb;
        padding: 30px;
        text-align: center;
        border-top: 1px solid #f1f5f9;
      }

      .footer p {
        font-size: 12px;
        color: #94a3b8;
        margin: 4px 0;
        line-height: 1.5;
      }

      @media screen and (max-width: 600px) {
        .container {
          width: 92%;
        }
        .content {
          padding: 30px 20px;
        }
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="container">
        <div class="header">
          <h1>MNA ServiceHub</h1>
        </div>

        <div class="content">
          <div class="status-badge">✓ Request Accepted</div>
          <h2>Service Assignment Details</h2>

          <p class="greeting">
            Hello, <span class="user-name"><%= name %></span>!<br />
            Your request for <strong><%= serviceName %></strong> has been
            accepted. We have assigned a professional for your service.
          </p>

          <div class="info-section">
            <div class="info-header">Service Summary</div>
            <div class="info-row">
              <span class="label">Request ID:</span>
              <span class="value">#<%= requestId %></span>
            </div>
            <div class="info-row">
              <span class="label">Placed At:</span>
              <span class="value text-sm"><%= requestTime %></span>
            </div>
            <div class="info-row">
              <span class="label">Service Address:</span>
              <span class="value"><%= serviceAddress %></span>
            </div>
            <div class="info-row">
              <span class="label">Contact:</span>
              <span class="value"><%= activePhone %></span>
            </div>
          </div>

          <div class="provider-card">
            <span class="provider-tag">ASSIGNED EXPERT</span>
            <div class="info-row">
              <span class="label">Name:</span>
              <span class="value"><%= providerName %></span>
            </div>
            <div class="info-row">
              <span class="label">Phone:</span>
              <span class="value"><%= providerPhone %></span>
            </div>
            <div
              class="info-row"
              style="
                margin-top: 15px;
                border-top: 1px dashed #cbd5e1;
                padding-top: 10px;
              "
            >
              <span class="label" style="color: #0052cc">Scheduled Time:</span>
              <span class="value" style="color: #0052cc"><%= schedule %></span>
            </div>
          </div>

          <p style="font-size: 13px; color: #94a3b8; text-align: center">
            Our expert will call you before arriving at your location.
          </p>
        </div>

        <div class="footer">
          <p>
            &copy; 2026 <strong>MNA ServiceHub</strong>. All rights reserved.
          </p>
          <p>Chittagong, Bangladesh</p>
          <p style="margin-top: 10px">
            System generated email. Please do not reply.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
